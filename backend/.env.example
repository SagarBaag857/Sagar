# Database Configuration
DATABASE_URL=postgresql://recipe_user:recipe_password@localhost:5432/recipe_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=recipe_db
DB_USER=recipe_user
DB_PASSWORD=recipe_password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Application Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ENVIRONMENT=development
DEBUG=True
API_VERSION=v1
APP_NAME=AI Recipe Generator

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4000

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.bmp,.webp
UPLOAD_DIRECTORY=uploads

# Computer Vision Configuration
CV_MODEL_PATH=models/ingredient_detection_model.h5
CV_CONFIDENCE_THRESHOLD=0.7
CV_MAX_DETECTIONS=50

# Recipe Generation Configuration
MAX_RECIPES_PER_REQUEST=10
DEFAULT_SERVING_SIZE=4
MAX_INGREDIENTS_PER_RECIPE=20

# Nutrition API Configuration
NUTRITION_API_KEY=your-nutrition-api-key
NUTRITION_API_URL=https://api.nal.usda.gov/fdc/v1

# Budget Mode Configuration
BUDGET_THRESHOLD_LOW=5.00
BUDGET_THRESHOLD_MEDIUM=15.00
BUDGET_THRESHOLD_HIGH=30.00

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@recipeai.com

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=['json']
CELERY_TIMEZONE=UTC

# Monitoring
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# Development Configuration
RELOAD=True
WORKERS=1

# Production Configuration (override in production)
# ENVIRONMENT=production
# DEBUG=False
# RELOAD=False
# WORKERS=4