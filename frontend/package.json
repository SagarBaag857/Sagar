{
  "name": "ai-recipe-generator-frontend",
  "version": "1.0.0",
  "description": "Frontend for AI Recipe Generator - Generate recipes from fridge items using computer vision and AI",
  "private": true,
  "keywords": ["react", "typescript", "recipe", "ai", "computer-vision", "food", "cooking"],
  "author": "AI Recipe Generator Team",
  "license": "MIT",
  "homepage": ".",
  "dependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "typescript": "^5.3.3",
    
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    
    "react-router-dom": "^6.20.1",
    "@types/react-router-dom": "^5.3.3",
    
    "axios": "^1.6.2",
    "@tanstack/react-query": "^5.12.2",
    "react-hook-form": "^7.48.2",
    "@hookform/resolvers": "^3.3.2",
    "zod": "^3.22.4",
    
    "framer-motion": "^10.16.16",
    "react-hot-toast": "^2.4.1",
    "react-dropzone": "^14.2.3",
    "react-intersection-observer": "^9.5.3",
    "react-use": "^17.4.0",
    
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "@types/lodash": "^4.14.202",
    "clsx": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    
    "react-cropper": "^2.3.3",
    "cropperjs": "^1.6.1",
    
    "chart.js": "^4.4.0",
    "react-chartjs-2": "^5.2.0",
    
    "lucide-react": "^0.294.0",
    "react-icons": "^4.12.0",
    
    "web-vitals": "^3.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    
    "tailwindcss": "^3.3.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.5.7",
    
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    
    "vite": "^5.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-react-swc": "^3.5.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    
    "dev": "vite",
    "build:vite": "vite build",
    "preview": "vite preview",
    
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx,css,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,css,md}",
    
    "type-check": "tsc --noEmit",
    "analyze": "npm run build && npx bundle-analyzer build/static/js/*.js",
    
    "prepare": "husky install"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,md}": [
      "prettier --write"
    ]
  },
  "proxy": "http://localhost:8000"
}